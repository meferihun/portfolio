@page "/"

<PageTitle>Ferenc Megyesi — .NET &amp; Blazor Developer</PageTitle>

<div id="top"></div>

<section class="hero">
    <div class="wrap hero-inner">
        <p class="eyebrow">// .NET &amp; Blazor Developer</p>
        <h1>
            I build fast, reliable<br />
            software with <span class="accent">.NET</span>.
        </h1>
        <p class="hero-lede">
            Hi, I'm <strong>Ferenc</strong> — a recent Computer Science graduate
            and junior developer with a year of hands-on enterprise experience.
            I care about clean architecture, testable code, and agile teamwork.
            This page itself is built with Blazor WebAssembly: no server, just static files running .NET in your browser.
        </p>
        <div class="hero-actions">
            <a href="#projects" class="btn btn-primary">View Projects</a>
            <a href="#contact" class="btn btn-ghost">Get in touch</a>
        </div>
    </div>
    <a href="#about" class="scroll-hint" aria-label="Scroll to About section">&darr;</a>
</section>

<section id="about" class="section">
    <div class="wrap">
        <p class="section-kicker">01 — Who I Am</p>
        <h2 class="section-title">About</h2>

        <div class="about-grid">
            <div class="about-copy">
                <p>
                   I'm a software developer focused on the .NET ecosystem — from ASP.NET Core APIs to Blazor frontends.
                   Over the past year at evosoft, I've transitioned from academic theory to enterprise reality:
                   writing unit tests, responding to code reviews, and collaborating within a cross-functional Scrum team.
                </p>
                <p>
                    I value pragmatic solutions, maintainable codebases, and continuous learning.
                    Whether I'm debugging business logic or building responsive UI components, my goal is always to deliver stable and clean software.
                </p>
            </div>

            <dl class="about-facts">
                <div>
                    <dt>Based in</dt>
                    <dd>Szeged, Hungary</dd>
                </div>
                <div>
                    <dt>Focus</dt>
                    <dd>.NET, ASP.NET Core, Blazor</dd>
                </div>
                <div>
                    <dt>Currently</dt>
                    <dd>Open to full-time junior roles</dd>
                </div>
                <div>
                    <dt>Resume</dt>
                    <dd><a href="/resume.pdf">Download PDF &darr;</a></dd>
                </div>
            </dl>
        </div>
    </div>
</section>

<section id="skills" class="section section-alt">
    <div class="wrap">
        <p class="section-kicker">02 — Toolbox</p>
        <h2 class="section-title">Skills &amp; Stack</h2>

        <div class="skills-grid">
            @foreach (var group in skillGroups)
            {
                <div class="skill-card">
                    <h3>@group.Category</h3>
                    <ul>
                        @foreach (var item in group.Items)
                        {
                            <li>@item</li>
                        }
                    </ul>
                </div>
            }
        </div>
    </div>
</section>

<section id="experience" class="section">
    <div class="wrap">
        <p class="section-kicker">03 — Journey</p>
        <h2 class="section-title">Experience</h2>

        <ol class="timeline">
            @foreach (var entry in timeline)
            {
                <li class="timeline-item">
                    <div class="timeline-period">@entry.Period</div>
                    <div class="timeline-body">
                        <h3>@entry.Title <span class="timeline-org">@entry.Org</span></h3>
                        <p>@entry.Description</p>
                    </div>
                </li>
            }
        </ol>
    </div>
</section>

<section id="projects" class="section section-alt">
    <div class="wrap">
        <p class="section-kicker">04 — Selected Work</p>
        <h2 class="section-title">Projects</h2>

        <div class="project-grid">
            @foreach (var project in projects)
            {
                <article class="project-card">
                    <h3>@project.Title</h3>
                    <p>@project.Description</p>
                    <div class="tag-row">
                        @foreach (var tag in project.Tags)
                        {
                            <span class="tag">@tag</span>
                        }
                    </div>
                    <div class="project-links">
                        @if (project.RepoUrl is not null)
                        {
                            <a href="@project.RepoUrl" target="_blank" rel="noopener">Code &rarr;</a>
                        }
                        @if (project.DemoUrl is not null)
                        {
                            <a href="@project.DemoUrl" target="_blank" rel="noopener">Live demo &rarr;</a>
                        }
                    </div>
                </article>
            }
        </div>
    </div>
</section>

<section id="contact" class="section">
    <div class="wrap contact-wrap">
        <p class="section-kicker">05 — Let's Talk</p>
        <h2 class="section-title">Contact</h2>
        <p class="contact-lede">
            Have a role, a project, or just want to talk about .NET and Blazor? My inbox is open.
        </p>

        <div class="contact-social">
            <a href="@Links.LinkedIn" target="_blank" rel="noopener" class="contact-link">
                <span class="contact-link-label">LinkedIn</span>
                <span class="contact-link-value">in/ferenc-megyesi &rarr;</span>
            </a>
            <a href="@Links.GitHub" target="_blank" rel="noopener" class="contact-link">
                <span class="contact-link-label">GitHub</span>
                <span class="contact-link-value">@@meferihun &rarr;</span>
            </a>
            <a href="@Links.Email" class="contact-link">
                <span class="contact-link-label">Email</span>
                <span class="contact-link-value">ferenc@megye.si &rarr;</span>
            </a>
        </div>
    </div>
</section>